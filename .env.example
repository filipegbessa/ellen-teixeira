# =============================================================================
# VARIÁVEIS DE AMBIENTE - CONFIGURAÇÕES TÉCNICAS
# =============================================================================
#
# IMPORTANTE: Este arquivo contém apenas configurações técnicas e de ambiente.
# Para editar informações do negócio (telefone, endereço, horários, etc),
# veja o arquivo: src/data/business.ts
#
# =============================================================================

# Site Configuration (muda entre dev/prod)
NEXT_PUBLIC_SITE_URL=https://draellenteixeira.com.br

# Analytics & Monitoring (configuração opcional, funciona automaticamente no Vercel)
# VERCEL_ANALYTICS_ID=
# VERCEL_SPEED_INSIGHTS_ID=

# Google Analytics (adicione seu ID do Google Analytics, ex: G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_ID=

# Google Maps — Place ID do consultório (formato ChIJ...)
# Atualizar quando o novo endereço estiver indexado no Google
# NEXT_PUBLIC_PLACE_ID=

# SEO Verification (adicione quando configurar os serviços)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_YANDEX_VERIFICATION=

# API Backend (ellen-api — NestJS)
# Se não configurado, a seção de avaliações exibe estado vazio
# Desenvolvimento: http://localhost:5555
# Produção: https://ellen-api-dun.vercel.app
# REVIEWS_API_URL=
